{
    "name": "renderingvideo/sdk",
    "description": "Official PHP SDK for RenderingVideo API - Video rendering and generation service",
    "keywords": ["renderingvideo", "video", "rendering", "sdk", "api","json-to-video"],
    "type": "library",
    "version": "1.0.0.2",
    "license": "MIT",
    "authors": [
        {
            "name": "RenderingVideo",
            "email": "support@renderingvideo.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "guzzlehttp/guzzle": "^7.5",
        "psr/http-client-implementation": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5|^10.0",
        "mockery/mockery": "^1.5",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "RenderingVideo\\SDK\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RenderingVideo\\SDK\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit",
        "check-style": "phpcs src tests",
        "fix-style": "phpcbf src tests"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
